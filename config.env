# CI configuration for UXC container pipeline
# Source this file from other CI scripts: . "$(dirname "$0")/config.env"

# OpenWrt EFI image for QEMU
OPENWRT_IMAGE="${OPENWRT_IMAGE:-$(ls "$REPO_ROOT"/openwrt-*-armsr-armv8-*-squashfs-combined-efi.img 2>/dev/null | head -1)}"

# OpenWrt SDK path (for apk mkpkg and signing key)
SDK_PATH="${SDK_PATH:-$REPO_ROOT/sdk}"

# Target architecture(s)
ARCH="${ARCH:-aarch64_generic}"
ARCHES="${ARCHES:-aarch64_generic x86_64}"

# Feed URL (for generated index.html instructions)
FEED_URL="${FEED_URL:-https://aparcar.org/uxc-action}"

# Build output directory
BUILD_DIR="${BUILD_DIR:-$REPO_ROOT/build}"

# QEMU settings
QEMU_SSH_PORT="${QEMU_SSH_PORT:-2222}"
QEMU_MEMORY="${QEMU_MEMORY:-512M}"
QEMU_PID_FILE="$BUILD_DIR/qemu.pid"
QEMU_IMG_WORK="$BUILD_DIR/openwrt-work.img"

# SSH settings for the QEMU guest
SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR"
SSH_TARGET="root@localhost"
SSH_PORT="$QEMU_SSH_PORT"
